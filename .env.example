cat > .env.example << 'EOF'
# ==================== DISCORD BOT TOKENS ====================
DISCORD_BOT_TOKEN_ANALYST=YOUR_ANALYST_BOT_TOKEN_HERE
DISCORD_BOT_TOKEN_STRATEGIST=YOUR_STRATEGIST_BOT_TOKEN_HERE
DISCORD_BOT_TOKEN_EXECUTOR=YOUR_EXECUTOR_BOT_TOKEN_HERE
DISCORD_BOT_TOKEN_MONITOR=YOUR_MONITOR_BOT_TOKEN_HERE
DISCORD_BOT_TOKEN_DEVELOPER=YOUR_DEVELOPER_BOT_TOKEN_HERE

# Guild ID (server Discord tempat bot akan dijalankan)
DISCORD_GUILD_ID=YOUR_GUILD_ID

# Channel IDs untuk logging & notifications
DISCORD_LOG_CHANNEL_ID=YOUR_LOG_CHANNEL_ID
DISCORD_ALERT_CHANNEL_ID=YOUR_ALERT_CHANNEL_ID
DISCORD_TRADE_LOG_CHANNEL_ID=YOUR_TRADE_LOG_CHANNEL_ID

# ==================== BINANCE API ====================
# JANGAN PERNAH GUNAKAN MAIN ACCOUNT UNTUK TESTING!
BINANCE_API_KEY=YOUR_BINANCE_API_KEY_HERE
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET_HERE

# Testnet endpoint (untuk dry-run)
BINANCE_TESTNET_ENABLED=true
BINANCE_TESTNET_API_KEY=YOUR_TESTNET_API_KEY
BINANCE_TESTNET_API_SECRET=YOUR_TESTNET_API_SECRET

# ==================== CLAUDE / ANTHROPIC ====================
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ==================== REDIS (State Management) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== GENERAL CONFIG ====================
NODE_ENV=development
LOG_LEVEL=info
TIMEZONE=Asia/Jakarta

# Risk Management
MAX_POSITION_SIZE=1000  # USD
MAX_DAILY_LOSS=-500     # USD
LEVERAGE=1              # 1 = no leverage

# Trading Pairs (comma-separated)
TRADING_PAIRS=BTC/USDT,ETH/USDT,BNB/USDT

# Webhook Port (untuk incoming data)
WEBHOOK_PORT=3000
WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_KEY

# ==================== SECURITY ====================
API_KEY_ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_FOR_API_KEYS
JWT_SECRET=YOUR_JWT_SECRET_FOR_INTERNAL_AUTH
EOF